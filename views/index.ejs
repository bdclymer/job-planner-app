<div class="dashboard-header">
    <h1>Project Management Dashboard</h1>
    <p class="text-muted">Welcome to Job Planner. Manage your construction projects, resources, and schedules in one place.</p>
</div>

<!-- Stats Overview -->
<div class="stats-grid mb-3">
    <div class="stat-card">
        <div class="stat-value" id="total-projects">0</div>
        <div class="stat-label">Total Projects</div>
    </div>
    <div class="stat-card">
        <div class="stat-value" id="active-jobs">0</div>
        <div class="stat-label">Active Jobs</div>
    </div>
    <div class="stat-card">
        <div class="stat-value" id="upcoming-tasks">0</div>
        <div class="stat-label">Upcoming Tasks</div>
    </div>
    <div class="stat-card">
        <div class="stat-value" id="total-resources">0</div>
        <div class="stat-label">Total Resources</div>
    </div>
</div>

<!-- Main Dashboard Grid -->
<div class="dashboard-grid">
    <!-- Projects Overview -->
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">Projects Overview</h2>
            <div class="card-icon projects">📋</div>
        </div>
        <div class="chart-container">
            <canvas id="project-status-chart" height="200"></canvas>
        </div>
        <div class="card-footer">
            <a href="/projects" class="btn btn-primary">View All Projects</a>
        </div>
    </div>

    <!-- Recent Projects -->
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">Recent Projects</h2>
            <div class="card-icon projects">📊</div>
        </div>
        <div class="table-container">
            <table class="table">
                <thead>
                    <tr>
                        <th>Project Name</th>
                        <th>Status</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="recent-projects-body">
                    <tr>
                        <td colspan="5" class="text-center">
                            <div class="loading">
                                <div class="spinner"></div>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Resource Utilization -->
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">Resource Utilization</h2>
            <div class="card-icon resources">⚙️</div>
        </div>
        <div class="chart-container">
            <canvas id="resource-utilization-chart" height="200"></canvas>
        </div>
        <div class="card-footer">
            <a href="/resources" class="btn btn-primary">Manage Resources</a>
        </div>
    </div>

    <!-- Upcoming Schedule -->
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">Upcoming Schedule</h2>
            <div class="card-icon schedule">📅</div>
        </div>
        <div id="upcoming-schedule">
            <div class="loading">
                <div class="spinner"></div>
            </div>
        </div>
        <div class="card-footer">
            <a href="/schedule" class="btn btn-primary">View Full Schedule</a>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">Quick Actions</h2>
            <div class="card-icon">🚀</div>
        </div>
        <div class="quick-actions">
            <div class="action-grid">
                <a href="/projects/new" class="action-card">
                    <div class="action-icon">➕</div>
                    <div class="action-title">New Project</div>
                    <div class="action-description">Create a new construction project</div>
                </a>
                <a href="/jobs/new" class="action-card">
                    <div class="action-icon">🔨</div>
                    <div class="action-title">New Job</div>
                    <div class="action-description">Add a new job to a project</div>
                </a>
                <a href="/schedule/new" class="action-card">
                    <div class="action-icon">📝</div>
                    <div class="action-title">Schedule Task</div>
                    <div class="action-description">Schedule a new task</div>
                </a>
                <a href="/reports" class="action-card">
                    <div class="action-icon">📈</div>
                    <div class="action-title">Generate Report</div>
                    <div class="action-description">Create project reports</div>
                </a>
            </div>
        </div>
    </div>

    <!-- System Status -->
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">System Status</h2>
            <div class="card-icon">🟢</div>
        </div>
        <div class="system-status">
            <div class="status-item">
                <div class="status-indicator online"></div>
                <div class="status-details">
                    <div class="status-title">API Server</div>
                    <div class="status-description">Connected and operational</div>
                </div>
            </div>
            <div class="status-item">
                <div class="status-indicator online"></div>
                <div class="status-details">
                    <div class="status-title">Database</div>
                    <div class="status-description">PostgreSQL connection active</div>
                </div>
            </div>
            <div class="status-item">
                <div class="status-indicator online"></div>
                <div class="status-details">
                    <div class="status-title">Job Planner API</div>
                    <div class="status-description">Integrated and responding</div>
                </div>
            </div>
            <div class="status-item">
                <div class="status-indicator online"></div>
                <div class="status-details">
                    <div class="status-title">Authentication</div>
                    <div class="status-description">JWT tokens working</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Additional Styles -->
