{
  "name": "job-planner-website",
  "version": "1.0.0",
  "description": "Modern project management website for construction job planning",
  "main": "server.js",
  "scripts": {
    "start": "node server-standalone.js",
    "dev": "nodemon server.js",
    "build": "npm run build:css && npm run build:js",
    "build:css": "postcss public/css/styles.css -o public/css/styles.min.css",
    "build:js": "uglifyjs public/js/*.js -o public/js/bundle.min.js",
    "test": "jest",
    "lint": "eslint ."
  },
  "keywords": [
    "project-management",
    "construction",
    "job-planner",
    "alleato"
  ],
  "author": "The Alleato Group",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "express-session": "^1.17.3",
    "connect-flash": "^0.1.1",
    "ejs": "^3.1.9",
    "moment": "^2.29.4",
    "chart.js": "^4.4.0",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.53.0",
    "postcss": "^8.4.31",
    "postcss-cli": "^10.1.0",
    "autoprefixer": "^10.4.16",
    "cssnano": "^6.0.1",
    "uglify-js": "^3.17.4"
  }
}